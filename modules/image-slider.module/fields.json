          "loading": "lazy"
        }
      },
      {
        "id": "caption",
        "name": "caption",
        "label": "Pie de imagen (opcional)",
        "type": "text",
        "default": ""
      }
    ]
  },
  {
    "id": "loop",
    "name": "loop",
    "label": "Bucle infinito",
    "type": "boolean",
    "default": true
  },
  {
    "id": "autoplay",
    "name": "autoplay",
    "label": "Reproducción automática",
    "type": "boolean",
    "default": false
  },
  {
    "id": "autoplay_delay",
    "name": "autoplay_delay",
    "label": "Intervalo de autoplay (ms)",
    "type": "number",
    "default": 4000,
    "min": 1000,
    "max": 10000
  },
  {
    "id": "settings",
    "name": "settings",
    "label": "Opciones visuales",
