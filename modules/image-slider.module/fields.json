        "type": "number",
        "default": 82,
        "min": 40,
        "max": 99
      },
      {
        "id": "inactive_opacity",
        "name": "inactive_opacity",
        "label": "Opacidad de slides inactivos (%)",
        "type": "number",
        "default": 65,
        "min": 10,
        "max": 100
