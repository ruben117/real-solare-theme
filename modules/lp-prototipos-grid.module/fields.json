[
  {
    "label": "Prototipos",
    "name": "items",
    "type": "group",
    "occurrence": {
      "default": 4,
      "min": 1,
      "max": 8,
      "sorting_label_field": "items.nombre"
    },
    "children": [
      {
        "label": "Imagen",
        "name": "imagen",
