        "type": "text",
        "default": "$1,099,000*"
      },
      {
        "label": "Enlace (opcional)",
        "name": "link",
        "type": "link",
        "supported_types": ["EXTERNAL", "CONTENT"],
        "default": {
          "url": { "href": "", "type": "EXTERNAL" },
          "open_in_new_tab": false,
          "no_follow": false
        }
      }
