      {
        "id": "title",
        "name": "title",
        "label": "Título",
        "type": "text",
        "default": "Título del artículo"
      },
      {
        "id": "excerpt",
        "name": "excerpt",
        "label": "Extracto",
        "type": "text",
        "default": "Breve descripción del artículo que invita al lector a conocer más."
